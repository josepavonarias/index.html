<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Comercial Lorena</title>

    <!-- Google Analytics (pega tu código aquí) -->
    <!-- Ejemplo:
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXX"></script>
    -->

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #eef2f3;
            margin: 0;
        }
        header {
            background: #2c3e50;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .container {
            width: 90%;
            margin: auto;
        }
        .card {
            background: white;
            padding: 20px;
            margin: 20px 0;
            border-radius: 12px;
            box-shadow: 0px 4px 10px rgba(0,0,0,0.1);
        }
        ul {
            list-style: none;
            padding: 0;
        }
        li {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }
        .whatsapp {
            display: inline-block;
            padding: 12px 20px;
            background: #25D366;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            margin-top: 10px;
        }
        canvas {
            max-width: 100%;
        }
    </style>
</head>

<body>

<header>
    <h1>Comercial Lorena</h1>
    <p>Venta de celulares, accesorios y recargas</p>
</header>

<div class="container">

    <div class="card">
        <h2>📦 Productos</h2>
        <ul>
            <li>📱 Celulares</li>
            <li>🎧 Accesorios</li>
            <li>💳 Recargas</li>
        </ul>
    </div>

    <div class="card">
        <h2>📊 Visitas por producto</h2>
        <canvas id="grafico1"></canvas>
    </div>

    <div class="card">
        <h2>🌐 Medio de acceso</h2>
        <canvas id="grafico2"></canvas>
    </div>

    <div class="card">
        <h2>📲 Contáctanos</h2>
        <p>Haz tu pedido por WhatsApp</p>
        <a class="whatsapp" href="https://wa.me/50588888888" target="_blank">
            Escribir por WhatsApp
        </a>
    </div>

</div>

<script>
    // Gráfico 1: Productos
    new Chart(document.getElementById('grafico1'), {
        type: 'bar',
        data: {
            labels: ['Celulares', 'Accesorios', 'Recargas'],
            datasets: [{
                label: 'Visitas',
                data: [15, 10, 7],
            }]
        }
    });

    // Gráfico 2: Medios
    new Chart(document.getElementById('grafico2'), {
        type: 'pie',
        data: {
            labels: ['WhatsApp', 'Directo', 'Facebook'],
            datasets: [{
                data: [12, 5, 8],
            }]
        }
    });
</script>

</body>
</html>
